# Mortal API - 环境配置
# 复制此文件为 .env 后编辑
# 管理后台登录后，在后台配置渠道和 API Key

# 管理员登录密码（务必修改！）
ADMIN_PASSWORD=admin123

# JWT 签名密钥 — 用于加密 DB 中存储的 API Key（务必修改！）
# 请使用一个足够长的随机字符串（建议 32 位以上）
# 设定后请勿修改，否则已加密的 API Key 将无法解密
JWT_SECRET=your-jwt-secret-change-in-production

# SQLite 数据库路径
DATABASE_PATH=data/relay.db
